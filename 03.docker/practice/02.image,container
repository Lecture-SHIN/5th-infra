--- 컨테이너 -e(MySQL:8.0)
# 실행 안됨 : -e 옵션 없음
docker run -d --name mydb mysql:8.0 
docker ps
docker ps -a
docker logs mydb
docker rm mydb


# 실행 성공 : -e 옵션 사용
# 외부에서 접근 불가능 : -p 옵션 없음
docker run -d --name mydb -e MYSQL_ROOT_PASSWORD=secret mysql:8.0
docker ps
docker rm -f $(docker ps -aq)
docker ps
docker ps -a

# 실행 실패 : 우분투 사용했던 mysql 포트 충돌 때문
# 외부에서 접근 가능 : -p 옵션 사용
docker run -d --name mydb -e MYSQL_ROOT_PASSWORD=secret -p 3306:3306 mysql:8.0

# 우분투 mysql 중지 : -p 3306:3306 옵션 충돌 방지
sudo systemctl status mysql
sudo systemctl stop mysql
sudo systemctl status mysql

# docker ps -a에 같은 이름이 있기 때문에 실행 실패
docker run -d --name mydb -e MYSQL_ROOT_PASSWORD=secret -p 3306:3306 mysql:8.0

# 최종 정상 실행
docker restart mydb
clear
docker ps 
docker logs mydb
