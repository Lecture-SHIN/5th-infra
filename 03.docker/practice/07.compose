--- 04.yml

ubuntu@ubuntu:~/docker/07.compose/syntax$ docker-compose -f docker-compose-04.yml config
name: syntax
services:
  app:
    command:
      - sh
      - -c
      - env && sleep 3600
    container_name: env-test
    environment:
      APP_NAME: my-spring-app
      APP_PORT: "8080"
      DB_HOST: localhost
      DB_PASSWORD: super_secret_password
      SPRING_PROFILES_ACTIVE: dev
    image: alpine
    networks:
      default: null
networks:
  default:
    name: syntax_default

