--- 
1. 기본 네트워크 탐색

# 현재 위치: /home/ubuntu/docker/06.network

# 1. docker network ls 로 기본 네트워크 목록 확인 (bridge, host, none)
# 2. docker network inspect bridge 로 기본 브리지 네트워크 상세 확인
#    (Subnet, Gateway 확인)
                {
                    "Subnet": "172.17.0.0/16",
                    "Gateway": "172.17.0.1"
                }

# 3. nginx 컨테이너 2개 실행 (기본 네트워크)
docker run --name web01 -d nginx
docker run --name web02 -d nginx

# 4. 각 컨테이너 IP 확인
docker inspect web01 | grep IPAddress
docker inspect web02 | grep IPAddress

# 5. web01 컨테이너 내부에서 web02 IP로 ping 테스트
ubuntu@ubuntu:~/docker/06.network$ docker inspect web01 | grep IPAddress
            "SecondaryIPAddresses": null,
            "IPAddress": "172.17.0.3",
                    "IPAddress": "172.17.0.3",
ubuntu@ubuntu:~/docker/06.network$ docker inspect web02 | grep IPAddress
            "SecondaryIPAddresses": null,
            "IPAddress": "172.17.0.4",
                    "IPAddress": "172.17.0.4",
ubuntu@ubuntu:~/docker/06.network$ docker exec web01 sh -c "ping -c 3 172.17.0
.4"
sh: 1: ping: not found
ubuntu@ubuntu:~/docker/06.network$ docker exec web01 sh -c "apt-get update -q && apt-get install -y -q iputils-ping 2>/dev/null; ping -c 3 172.17.0.4"
