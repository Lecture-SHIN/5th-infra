# 6. web01 컨테이너 내부에서 web02 이름으로 ping 테스트 → 실패 확인 (기본 bridge는 DNS 불가)
ubuntu@ubuntu:~/docker/06.network$ docker exec web01 ping -c web02
ping: invalid argument: 'web02'

# 7. docker rm -f web01 web02 로 정리

---
2. 사용자 정의 네트워크 생성 및 컨테이너 연결
# 현재 위치: /home/ubuntu/docker/06.network

# 1. 사용자 정의 네트워크 생성
docker network create app-network

# 2. docker network ls 로 생성 확인
                {
                    "Subnet": "172.18.0.0/16",
                    "Gateway": "172.18.0.1"
                }

# 3. 동일 네트워크에 컨테이너 2개 실행
docker run --name svc01 --network app-network -d nginx
docker run --name svc02 --network app-network -d nginx

# 4. docker network inspect app-network 로 연결된 컨테이너 확인
ubuntu@ubuntu:~/docker/06.network$ docker inspect svc01 | grep IPAddress
            "SecondaryIPAddresses": null,
            "IPAddress": "",
                    "IPAddress": "172.18.0.2",
ubuntu@ubuntu:~/docker/06.network$ docker inspect svc02 | grep IPAddress
            "SecondaryIPAddresses": null,
            "IPAddress": "",
                    "IPAddress": "172.18.0.3",

# 5. svc01 → svc02 이름으로 통신 테스트 (DNS 동작 확인)
ubuntu@ubuntu:~/docker/06.network$ docker exec svc01 sh -c "apt-get update -q 
&& apt-get install -y -q iputils-ping 2>/dev/null; ping -c 3 172.18.0.3"
ubuntu@ubuntu:~/docker/06.network$ docker exec svc02 sh -c "apt-get update -q 
&& apt-get install -y -q iputils-ping 2>/dev/null; ping -c 3 172.18.0.2"

ubuntu@ubuntu:~/docker/06.network$ docker exec svc01 sh -c "curl -s http://172.18.0.3 | head -5"
<!DOCTYPE html>
<html>
<head>
<title>Welcome to nginx!</title>
<style>
ubuntu@ubuntu:~/docker/06.network$ docker exec svc01 sh -c "curl -s http://svc02 | head -5"
<!DOCTYPE html>
<html>
<head>
<title>Welcome to nginx!</title>
<style>
ubuntu@ubuntu:~/docker/06.network$ docker exec svc01 ping -c 3 svc02
PING svc02 (172.18.0.3) 56(84) bytes of data.
