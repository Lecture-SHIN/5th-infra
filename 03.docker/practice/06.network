ubuntu@ubuntu:~/docker/06.network$ docker exec svc02 sh -c "curl -s http://172.18.0.2 | head -5"
<!DOCTYPE html>
<html>
<head>
<title>Welcome to nginx!</title>
<style>
ubuntu@ubuntu:~/docker/06.network$ docker exec svc02 sh -c "curl -s http://svc01 | head -5"
<!DOCTYPE html>
<html>
<head>
<title>Welcome to nginx!</title>
<style>

# 6. 새 컨테이너(svc03)를 기본 네트워크로 실행 후 app-network 에 추가 연결
docker run --name svc03 -d nginx
ubuntu@ubuntu:~/docker/06.network$ docker network connect app-network svc03

# 7. docker inspect svc03 | grep "IPAddress" 로 멀티 네트워크 확인
# 8. 정리

ubuntu@ubuntu:~/docker/06.network$ docker exec svc01 cat /etc/resolv.conf
# Generated by Docker Engine.
# This file can be edited; Docker Engine will not make further changes once it
# has been modified.

nameserver 127.0.0.11
search .
options edns0 trust-ad ndots:0

# Based on host file: '/etc/resolv.conf' (internal resolver)
# ExtServers: [host(127.0.0.53)]
# Overrides: []
# Option ndots from: internal
ubuntu@ubuntu:~/docker/06.network$ docker exec svc02 cat /etc/resolv.conf
# Generated by Docker Engine.
# This file can be edited; Docker Engine will not make further changes once it
# has been modified.

nameserver 127.0.0.11
search .
options edns0 trust-ad ndots:0

# Based on host file: '/etc/resolv.conf' (internal resolver)
# ExtServers: [host(127.0.0.53)]
# Overrides: []
# Option ndots from: internal