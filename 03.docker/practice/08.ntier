# 현재 위치: /home/ubuntu/docker/08.ntier

# 1. 현재 서비스 실행 상태에서 backend 이미지만 재빌드
#    (Dockerfile 또는 jar 변경 후)
docker-compose up --build -d backend

# 2. docker-compose ps 로 backend 컨테이너가 재생성되었는지 확인
# 3. docker-compose logs backend 로 새 버전 기동 로그 확인
# 4. DB 컨테이너는 그대로 유지되는지 docker-compose ps 로 확인
ubuntu@ubuntu:~/infra-basic-deploy-lab/infra-basic-backend$ docker ps
