--- ps
ps
ps --forest
ps aux
ps -ef
ps -u ubuntu
ps -ef --forest
ps -p 1017
ps -p 1017 -o pid,ppid,%cpu,%mem

--- jobs, fg, bg
jobs
sleep 300
jobs
ps -ef | grep sleep
bg %1
jobs
sleep 300
bg %1
jobs
fg %1
jobs
sleep 300 &
ps -p 1113
jobs
kill -15 %1
jobs

--- kill
ubuntu@ubuntu:~/14.process$ sleep 1000&
[1] 1120
ubuntu@ubuntu:~/14.process$ sleep 2000&
[2] 1121
ubuntu@ubuntu:~/14.process$ sleep 3000&
[3] 1122
ubuntu@ubuntu:~/14.process$ jobs
[1]   Running                 sleep 1000 &
[2]-  Running                 sleep 2000 &
[3]+  Running                 sleep 3000 &
ubuntu@ubuntu:~/14.process$ ps aux | grep sleep
ubuntu      1120  0.0  0.0   7004  2128 pts/0    S    10:42   0:00 sleep 1000
ubuntu      1121  0.0  0.0   7004  2128 pts/0    S    10:42   0:00 sleep 2000
ubuntu      1122  0.0  0.0   7004  2132 pts/0    S    10:42   0:00 sleep 3000
ubuntu      1124  0.0  0.0   7864  2356 pts/0    S+   10:43   0:00 grep --color=auto sleep
ubuntu@ubuntu:~/14.process$ ps aux | grep -v grep | grep sleep
ubuntu      1120  0.0  0.0   7004  2128 pts/0    S    10:42   0:00 sleep 1000
ubuntu      1121  0.0  0.0   7004  2128 pts/0    S    10:42   0:00 sleep 2000
ubuntu      1122  0.0  0.0   7004  2132 pts/0    S    10:42   0:00 sleep 3000
ubuntu@ubuntu:~/14.process$ kill 1120
ubuntu@ubuntu:~/14.process$ ps aux | grep -v grep | grep sleep
ubuntu      1121  0.0  0.0   7004  2128 pts/0    S    10:42   0:00 sleep 2000
ubuntu      1122  0.0  0.0   7004  2132 pts/0    S    10:42   0:00 sleep 3000
[1]   Terminated              sleep 1000
ubuntu@ubuntu:~/14.process$ kill -9 1121
ubuntu@ubuntu:~/14.process$ ps aux | grep -v grep | grep sleep
ubuntu      1122  0.0  0.0   7004  2132 pts/0    S    10:42   0:00 sleep 3000
[2]-  Killed                  sleep 2000
ubuntu@ubuntu:~/14.process$ man pkill
ubuntu@ubuntu:~/14.process$ pkill -f "sleep 3000"
[3]+  Terminated              sleep 3000
ubuntu@ubuntu:~/14.process$ sleep 100&
[1] 1154
ubuntu@ubuntu:~/14.process$ sleep 200&
[2] 1155
ubuntu@ubuntu:~/14.process$ sleep 300&
[3] 1156
ubuntu@ubuntu:~/14.process$ ps aux | grep -v grep | grep sleep
ubuntu      1154  0.0  0.0   7004  2132 pts/0    S    10:49   0:00 sleep 100
ubuntu      1155  0.0  0.0   7004  2128 pts/0    S    10:49   0:00 sleep 200
ubuntu      1156  0.0  0.0   7004  2132 pts/0    S    10:49   0:00 sleep 300
ubuntu@ubuntu:~/14.process$ killall sleep
[1]   Terminated              sleep 100
[2]-  Terminated              sleep 200
ubuntu@ubuntu:~/14.process$ ps aux | grep -v grep | grep sleep
[3]+  Terminated              sleep 300

--- nohup
ubuntu@ubuntu:~/14.process$ nohup sleep 1000 &
[1] 1179
ubuntu@ubuntu:~/14.process$ nohup: ignoring input and appending output to 'nohup.out'

ubuntu@ubuntu:~/14.process$ ls
nohup.out
ubuntu@ubuntu:~/14.process$ cat nohup.out 
ubuntu@ubuntu:~/14.process$ echo $!
1179
ubuntu@ubuntu:~/14.process$ ls -l nohup.out 
-rw------- 1 ubuntu ubuntu 0 Mar 19 11:04 nohup.out
ubuntu@ubuntu:~/14.process$ cat nohup.out 
ubuntu@ubuntu:~/14.process$ nohup sleep 2000 > sleep_2000.log 2>&1 &
[2] 1194
ubuntu@ubuntu:~/14.process$ ls
nohup.out  sleep_2000.log
ubuntu@ubuntu:~/14.process$ nohup sleep 3000 > sleep_3000.log 2>&1 &
[3] 1196
ubuntu@ubuntu:~/14.process$ echo $! > app.pid
ubuntu@ubuntu:~/14.process$ cat app.pid
1196
ubuntu@ubuntu:~/14.process$ kill $(cat app.pid)
ubuntu@ubuntu:~/14.process$ ps aux | grep -v grep | grep "sleep 3000"
[3]+  Terminated              nohup sleep 3000 > sleep_3000.log 2>&1
ubuntu@ubuntu:~/14.process$ cat app.pid 
1196
ubuntu@ubuntu:~/14.process$ rm app.pid 
ubuntu@ubuntu:~/14.process$ ps aux | grep nohup
ubuntu      1215  0.0  0.0   7864  2352 pts/0    S+   11:12   0:00 grep --color=auto nohup
ubuntu@ubuntu:~/14.process$ jobs
[1]-  Running                 nohup sleep 1000 &
[2]+  Running                 nohup sleep 2000 > sleep_2000.log 2>&1 &
ubuntu@ubuntu:~/14.process$ pkill -f "sleep 1000"
ubuntu@ubuntu:~/14.process$ pkill -f "sleep 2000"
[1]-  Terminated              nohup sleep 1000
[2]+  Terminated              nohup sleep 2000 > sleep_2000.log 2>&1
ubuntu@ubuntu:~/14.process$ jobs

--- 
1. Spring Boot 프로세스 확인 및 관리
# 현재 위치: /home/ubuntu/14.process

# 1. ps aux 로 전체 프로세스 확인
# 2. ps aux | grep sleep 으로 sleep 프로세스만 필터
# 3. ps aux --sort=-%cpu | head -5 로 CPU 상위 5개 확인
# 4. sleep 프로세스 중 하나의 PID 확인 후 kill -15 로 정상 종료
# 5. kill -9 로 다른 sleep 프로세스 강제 종료
# 6. pkill -f "sleep 500" 으로 패턴 매칭 종료
# 7. ps aux | grep sleep 으로 모두 종료됐는지 확인

--- 
2. 백그라운드 작업 관리
# 현재 위치: /home/ubuntu/14.process

# 1. sleep 200 실행 → Ctrl+Z 로 일시 중지
# 2. jobs 로 작업 목록 확인
# 3. bg %1 로 백그라운드 재개
# 4. jobs 로 상태 변화 확인
# 5. fg %1 로 포그라운드로 전환 → Ctrl+C 로 종료
# 6. nohup sleep 1000 > sleep.log 2>&1 & 로 백그라운드 실행
# 7. echo $! 로 PID 확인 → app.pid 파일로 저장
# 8. kill $(cat app.pid) 로 종료

ubuntu@ubuntu:~/14.process$ sleep 200
^Z
[1]+  Stopped                 sleep 200
ubuntu@ubuntu:~/14.process$ jobs
[1]+  Stopped                 sleep 200
ubuntu@ubuntu:~/14.process$ bg %1
[1]+ sleep 200 &
ubuntu@ubuntu:~/14.process$ jobs
[1]+  Running                 sleep 200 &
ubuntu@ubuntu:~/14.process$ fg %1
sleep 200
^C
ubuntu@ubuntu:~/14.process$ nohup sleep 1000 > sleep.log 2>&1 &
[1] 1275
ubuntu@ubuntu:~/14.process$ echo $! > app.id
ubuntu@ubuntu:~/14.process$ kill $(cat app.id)
ubuntu@ubuntu:~/14.process$ ps -ef | grep sleep

--- 
3. 프로세스 트리 및 자원 사용 분석
# 현재 위치: /home/ubuntu/14.process

# 1. ps -ef --forest 로 프로세스 트리 확인
# 2. 메모리 사용 상위 10개
ubuntu@ubuntu:~/14.process$ ps aux --sort=-%mem | head -10
USER         PID %CPU %MEM    VSZ   RSS TTY      STAT START   TIME COMMAND
root        1037  0.0  1.0 479436 41740 ?        Ssl  10:14   0:01 /usr/libexec/fwupd/fwupd
root         354  0.0  0.6 289116 27452 ?        SLsl 10:03   0:01 /sbin/multipathd -d -s
root         299  0.0  0.4  66864 17480 ?        S<s  10:03   0:00 /usr/lib/systemd/systemd-journald
root         669  0.0  0.3 468980 13720 ?        Ssl  10:03   0:00 /usr/libexec/udisks2/udisksd
root           1  0.0  0.3  22132 13276 ?        Ss   10:03   0:03 /sbin/init
systemd+     532  0.0  0.3  21592 13012 ?        Ss   10:03   0:00 /usr/lib/systemd/systemd-resolved
root         714  0.0  0.3 392096 13008 ?        Ssl  10:03   0:00 /usr/sbin/ModemManager
ubuntu       791  0.0  0.2  20332 11480 ?        Ss   10:03   0:00 /usr/lib/systemd/systemd --user
root         748  0.0  0.2  14740 10560 ?        Ss   10:03   0:00 sshd: ubuntu [priv]

# 3. PID 1(systemd) 정보 확인
ubuntu@ubuntu:~/14.process$ ps -p 1 -o pid,ppid,cmd
    PID    PPID CMD
      1       0 /sbin/init


# 4. 전체 메모리 사용률 합산
# hint : awk
ubuntu@ubuntu:~/14.process$ ps aux | awk 'NR > 1 {sum += $4} END {print "총 메모리 사용률:", sum}'
총 메모리 사용률: 5.5

# 5. 전체 프로세스 수 확인
# hint : wc
ubuntu@ubuntu:~/14.process$ ps aux | wc -l
101

# 6. 메모리를 가장 많이 사용하는 프로세스를 1개만 출력
# USER, PID, MEM, COMMAND
ubuntu@ubuntu:~/14.process$ ps aux --sort=-%mem | awk 'NR == 2 {print $0}'
root        1037  0.0  1.0 604760 43668 ?        Ssl  10:14   0:04 /usr/libexec/fwupd/fwupd
ubuntu@ubuntu:~/14.process$ ps aux --sort=-%mem | awk 'NR < 2 {print $0}'
USER         PID %CPU %MEM    VSZ   RSS TTY      STAT START   TIME COMMAND
ubuntu@ubuntu:~/14.process$ ps aux --sort=-%mem | awk 'NR == 2 {print $1, $2, $4, $11}'
root 1037 1.0 /usr/libexec/fwupd/fwupd
