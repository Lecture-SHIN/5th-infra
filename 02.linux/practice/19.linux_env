--- 변수
ubuntu@ubuntu:~/19.env$ env | wc -l
23
ubuntu@ubuntu:~/19.env$ printenv | wc -l
23
ubuntu@ubuntu:~/19.env$ echo $HOME
/home/ubuntu
ubuntu@ubuntu:~/19.env$ echo $PATH
/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/snap/bin
ubuntu@ubuntu:~/19.env$ echo $USER
ubuntu
ubuntu@ubuntu:~/19.env$ printenv PATH
/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/snap/bin
ubuntu@ubuntu:~/19.env$ printenv DB_HOST
ubuntu@ubuntu:~/19.env$ echo $DB_HOST

ubuntu@ubuntu:~/19.env$ export DB_HOST="localhost"
ubuntu@ubuntu:~/19.env$ echo $DB_HOST
localhost
ubuntu@ubuntu:~/19.env$ unset DB_HOST
ubuntu@ubuntu:~/19.env$ echo $DB_HOST

--- export 사용 : 하위 프로세스에 변수 전달
ubuntu@ubuntu:~/19.env$ MY_VAR=hello
ubuntu@ubuntu:~/19.env$ echo $MY_VAR
hello
ubuntu@ubuntu:~/19.env$ export MY_VAR2=hello2
ubuntu@ubuntu:~/19.env$ echo $MY_VAR2
hello2
ubuntu@ubuntu:~/19.env$ bash -c 'echo "$MY_VAR"'

ubuntu@ubuntu:~/19.env$ bash -c 'echo "$MY_VAR2"'
hello2


--- 출력
ubuntu@ubuntu:~/19.env$ env | grep -E "DB_|MY_"
MY_VAR2=hello2

--- 변수 반영
ubuntu@ubuntu:~/19.env$ echo $0
-bash
ubuntu@ubuntu:~/19.env$ cat /etc/environment 
PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/snap/bin"
ubuntu@ubuntu:~/19.env$ sudo cat /etc/environment 
[sudo] password for ubuntu: 
PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/snap/bin"
ubuntu@ubuntu:~/19.env$ sudo cat /etc/profile
# /etc/profile: system-wide .profile file for the Bourne shell (sh(1))
# and Bourne compatible shells (bash(1), ksh(1), ash(1), ...).

if [ "${PS1-}" ]; then
  if [ "${BASH-}" ] && [ "$BASH" != "/bin/sh" ]; then
    # The file bash.bashrc already sets the default PS1.
    # PS1='\h:\w\$ '
    if [ -f /etc/bash.bashrc ]; then
      . /etc/bash.bashrc
    fi
  else
    if [ "$(id -u)" -eq 0 ]; then
      PS1='# '
    else
      PS1='$ '
    fi
  fi
fi

if [ -d /etc/profile.d ]; then
  for i in /etc/profile.d/*.sh; do
    if [ -r $i ]; then
      . $i
    fi
  done
  unset i
fi

--- 
1. 애플리케이션 환경변수 설정

# 현재 위치: /home/ubuntu/19.env

# 1. 현재 환경변수 전체 확인 (env)
# 2. 아래 환경변수를 export 로 설정
#    APP_ENV=production
#    DB_HOST=prod-db.internal
#    DB_PORT=3306
#    REDIS_HOST=prod-redis.internal
#    JAVA_OPTS="-Xmx512m -Xms256m"
# 3. echo 로 각 변수 값 확인
# 4. "APP_|DB_|REDIS_|JAVA_" 로 설정한 변수만 필터
# 5. 새 bash 셸 실행 후 echo $APP_ENV 확인
# 6. unset DB_HOST 후 echo $DB_HOST 로 삭제 확인

ubuntu@ubuntu:~/19.env$ export APP_ENV=production
ubuntu@ubuntu:~/19.env$ echo $APP_ENV
production
ubuntu@ubuntu:~/19.env$ env | grep -E "APP_"
APP_ENV=production

---
2. .bashrc 커스터마이징
# 1. ~/.bashrc 백업
cp ~/.bashrc ~/.bashrc.bak

# 2. ~/.bashrc 에 아래 내용 추가 (vim 또는 echo >> 사용)
#    alias ll='ls -alh'
#    alias ..='cd ..'
#    alias cdlog='cd /var/log'
#    export HISTSIZE=10000
#    export HISTTIMEFORMAT="%Y-%m-%d %H:%M:%S "

# 3. source ~/.bashrc 로 즉시 적용
# 4. ll 명령어로 alias 동작 확인
# 5. history 로 타임스탬프 포함 출력 확인
# 6. ~/.bashrc 에 mkcd 함수 추가
#    mkcd() { mkdir -p "$1" && cd "$1"; }
# 7. source 후 mkcd /home/ubuntu/19.env/testdir 로 동작 확인

