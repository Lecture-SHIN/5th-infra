--- practice_variable.sh
ubuntu@ubuntu:~/27.script$ cat practice_variable.sh 
#!/bin/bash

APP="spring-boot-app"
VERSION="3.5.9"
TODAY=$(date +%Y-%m-%d)

echo "앱 이름: $APP"
echo "버전: ${VERSION}"
echo "오늘 날짜: $TODAY"
echo "스크립트명: $0"
echo "인자 개수: $#"
echo "첫 번째 인자: $1"

ls /home/ubuntu > /dev/null 2>&1
echo "직전 명령: $?"

echo "현재 스크립트 PID: $$"

sleep 5&
echo "백그라운드 PID:$!"

