3. 보안 점검 : 위험 권한 파일 탐지 및 수정
# 현재 위치: /home/ubuntu/07.permission

# 1. find로 권한이 정확히 777인 파일 검색
# 2. secret.key → 600 으로 변경
# 3. old_deploy.sh → 755 로 변경
# 4. find로 777 파일이 없어졌는지 재확인
# 5. umask 확인 후, 새 파일 touch test.txt 생성 → ls -l 로 기본 권한 확인
ubuntu@ubuntu:~/07.permission$ sudo chown -R ubuntu app/
ubuntu@ubuntu:~/07.permission$ ll
total 12
drwxrwxr-x  3 ubuntu ubuntu 4096 Mar 17 15:24 ./
drwxr-x--- 11 ubuntu ubuntu 4096 Mar 17 15:08 ../
drwxrwxr-x  5 ubuntu ubuntu 4096 Mar 17 15:08 app/
-rw-r--r--  1 ubuntu ubuntu    0 Mar 17 15:24 chown_test.txt
-rw-r--r--  1 ubuntu ubuntu    0 Mar 17 15:15 umask_test.txt
ubuntu@ubuntu:~/07.permission$ touch app/config/secret.key
chmod 777 app/config/secret.key
touch app/deploy/old_deploy.sh
chmod 777 app/deploy/old_deploy.sh
ubuntu@ubuntu:~/07.permission$ find . -perm 777 -type f
./app/config/secret.key
./app/deploy/old_deploy.sh
find: ‘./app/logs/app.log’: Permission denied
ubuntu@ubuntu:~/07.permission$ chmod 600 app/config/secret.key 
ubuntu@ubuntu:~/07.permission$ ll app/config/secret.key 
-rw------- 1 ubuntu ubuntu 0 Mar 17 15:48 app/config/secret.key
ubuntu@ubuntu:~/07.permission$ chmod 755 app/deploy/old_deploy.sh 
ubuntu@ubuntu:~/07.permission$ ll app/deploy/old_deploy.sh 
-rwxr-xr-x 1 ubuntu ubuntu 0 Mar 17 15:48 app/deploy/old_deploy.sh*
ubuntu@ubuntu:~/07.permission$ find . -perm 777 -type f
find: ‘./app/logs/app.log’: Permission denied
ubuntu@ubuntu:~/07.permission$ umask
0022
ubuntu@ubuntu:~/07.permission$ touch test.txt
ubuntu@ubuntu:~/07.permission$ ll test.txt 
-rw-r--r-- 1 ubuntu ubuntu 0 Mar 17 15:51 test.txt