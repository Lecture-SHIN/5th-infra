---
1. 배포 스크립트 권한 설정
# 현재 위치: /home/ubuntu/07.permission

# 1. ls -l app/deploy/ 로 현재 권한 확인
# 2. deploy.sh, rollback.sh 에 실행 권한 추가 (chmod +x)
# 3. application-prod.yml 을 소유자만 읽기/쓰기 가능하게 (600)
# 4. app/logs/ 하위 전체를 그룹 읽기 가능하게 재귀 적용 (664)
# 5. ls -l 로 각 파일 권한 최종 확인
ubuntu@ubuntu:~/07.permission$ ls -l app/deploy/
total 0
-rwxr-xr-x 1 ubuntu ubuntu 0 Mar 17 15:35 deploy.sh
-rwxr-xr-x 1 ubuntu ubuntu 0 Mar 17 15:35 rollback.sh
ubuntu@ubuntu:~/07.permission$ chmod +x app/deploy/deploy.sh  app/deploy/rollback.sh 
ubuntu@ubuntu:~/07.permission$ chmod -x app/deploy/deploy.sh
  app/deploy/rollback.sh 
ubuntu@ubuntu:~/07.permission$ ls -l app/deploy/
total 0
-rw-r--r-- 1 ubuntu ubuntu 0 Mar 17 15:35 deploy.sh
-rw-r--r-- 1 ubuntu ubuntu 0 Mar 17 15:35 rollback.sh
ubuntu@ubuntu:~/07.permission$ chmod +x app/deploy/deploy.sh
  app/deploy/rollback.sh 
ubuntu@ubuntu:~/07.permission$ ls -l app/deploy/
total 0
-rwxr-xr-x 1 ubuntu ubuntu 0 Mar 17 15:35 deploy.sh
-rwxr-xr-x 1 ubuntu ubuntu 0 Mar 17 15:35 rollback.sh
ubuntu@ubuntu:~/07.permission$ chmod 600 app/config/application-prod.yml 
ubuntu@ubuntu:~/07.permission$ ls -l app/config/application-
prod.yml 
-rw------- 1 ubuntu ubuntu 0 Mar 17 15:35 app/config/application-prod.yml
ubuntu@ubuntu:~/07.permission$ chmod -R 664 app/logs/
ubuntu@ubuntu:~/07.permission$ sudo ll app/logs/app.log 
[sudo] password for ubuntu: 
sudo: ll: command not found
ubuntu@ubuntu:~/07.permission$ sudo ls -al app/logs/app.log 
-rw-rw-r-- 1 ubuntu ubuntu 0 Mar 17 15:35 app/logs/app.log

---
2.서비스 계정 소유권 설정
# 현재 위치: /home/ubuntu/07.permission

# 1. app/ 디렉터리 전체 소유자를 appuser 로 재귀 변경
# 2. ls -l app/ 로 소유자 변경 확인
# 3. app/config/ 소유자를 다시 ubuntu 로 재귀 변경 (설정 파일은 관리자가 수정)
# 4. ls -l app/config/ 로 확인

ubuntu@ubuntu:~/07.permission$ sudo useradd -r -s /bin/false appuser
ubuntu@ubuntu:~/07.permission$ ll app/
total 20
drwxrwxr-x 5 ubuntu ubuntu 4096 Mar 17 15:08 ./
drwxrwxr-x 3 ubuntu ubuntu 4096 Mar 17 15:24 ../
drwxrwxr-x 2 ubuntu ubuntu 4096 Mar 17 15:08 config/
drwxr-xr-x 2 ubuntu ubuntu 4096 Mar 17 15:08 deploy/
drw-rw-r-- 2 ubuntu ubuntu 4096 Mar 17 15:08 logs/
ubuntu@ubuntu:~/07.permission$ sudo chown -R appuser app/
ubuntu@ubuntu:~/07.permission$ ll app/
total 20
drwxrwxr-x 5 appuser ubuntu 4096 Mar 17 15:08 ./
drwxrwxr-x 3 ubuntu  ubuntu 4096 Mar 17 15:24 ../
drwxrwxr-x 2 appuser ubuntu 4096 Mar 17 15:08 config/
drwxr-xr-x 2 appuser ubuntu 4096 Mar 17 15:08 deploy/
drw-rw-r-- 2 appuser ubuntu 4096 Mar 17 15:08 logs/
ubuntu@ubuntu:~/07.permission$ sudo chown -R ubuntu app/conf
ig/
