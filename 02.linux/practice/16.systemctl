--- 시스템 등록
ubuntu@ubuntu:~/16.systemctl$ pwd
/home/ubuntu/16.systemctl
ubuntu@ubuntu:~/16.systemctl$ mkdir -p app/logs
ubuntu@ubuntu:~/16.systemctl$ ls
app
ubuntu@ubuntu:~/16.systemctl$ cat > app/run.sh << 'EOF'
#!/bin/bash
echo "=== 서비스 시작: $(date) ==="
echo "PID: $$"

COUNT=0
while true; do
    COUNT=$((COUNT + 1))
    echo "$(date '+%Y-%m-%d %H:%M:%S') [INFO] 서비스  실행 중 - 요청수: $COUNT"
    sleep 5
done
EOF
