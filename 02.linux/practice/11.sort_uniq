--- uniq
ubuntu@ubuntu:~/11.sort_uniq$ cat names.txt 
Charlie
alice
Bob
dave
Alice
bob
Charlie
ubuntu@ubuntu:~/11.sort_uniq$ uniq names.txt 
Charlie
alice
Bob
dave
Alice
bob
Charlie
ubuntu@ubuntu:~/11.sort_uniq$ sort names.txt | uniq
alice
Alice
bob
Bob
Charlie
dave
ubuntu@ubuntu:~/11.sort_uniq$ sort names.txt | uniq -c
      1 alice
      1 Alice
      1 bob
      1 Bob
      2 Charlie
      1 dave
ubuntu@ubuntu:~/11.sort_uniq$ sort names.txt | uniq -d
Charlie
ubuntu@ubuntu:~/11.sort_uniq$ sort names.txt | uniq -u
alice
Alice
bob
Bob
dave
ubuntu@ubuntu:~/11.sort_uniq$ sort names.txt | uniq -c
      1 alice
      1 Alice
      1 bob
      1 Bob
      2 Charlie
      1 dave
ubuntu@ubuntu:~/11.sort_uniq$ sort names.txt | uniq -c | sort -rn
      2 Charlie
      1 dave
      1 Bob
      1 bob
      1 Alice
      1 alice

