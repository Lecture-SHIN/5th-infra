--- tr
ubuntu@ubuntu:~/11.sort_uniq$ echo "hello" | tr 'a-z' 'A-Z'
HELLO
ubuntu@ubuntu:~/11.sort_uniq$ echo "a:b:c" | tr ':' ','
a,b,c
ubuntu@ubuntu:~/11.sort_uniq$ cat from-window-file | tr -d '\r'
cat: from-window-file: No such file or directory
ubuntu@ubuntu:~/11.sort_uniq$ echo "aabbcc" | tr -s 'a-z'
abc
ubuntu@ubuntu:~/11.sort_uniq$ cat from-file | tr -cd '0-9\n'
cat: from-file: No such file or directory

 