3. 하드 링크로 중요 설정 파일 보호
# 현재 위치: /home/ubuntu/05.link

# 1. app/config/application.yml 의 하드 링크를 backup/config/application.yml 로 생성
# 2. ls -l 로 두 파일의 링크 카운트(2) 확인
# 3. find . -type f -links +1 로 하드 링크가 걸린 파일 검색
# 4. 원본(app/config/application.yml) 삭제
# 5. backup/config/application.yml 내용이 유지되는지 cat 으로 확인 (하드 링크 특성 검증)
# 6. ls -l backup/config/application.yml 로 링크 카운트가 1로 줄었는지 확인

ubuntu@ubuntu:~/05.link$ tree app
app
└── config
    └── application.yml

2 directories, 1 file
ubuntu@ubuntu:~/05.link$ tree backup/
backup/
├── application.yml.hard
└── config

2 directories, 1 file
ubuntu@ubuntu:~/05.link$ ln /home/ubuntu/05.link/app/config/
application.yml /home/ubuntu/05.link/backup/config/application.yml
ubuntu@ubuntu:~/05.link$ tree backup
backup
├── application.yml.hard
└── config
    └── application.yml

2 directories, 2 files
ubuntu@ubuntu:~/05.link$ ls -ail backup/config/application.y
ml 
454194 -rw-rw-r-- 3 ubuntu ubuntu 144 Mar 17 11:34 backup/config/application.yml
ubuntu@ubuntu:~/05.link$ find . -type f -links +1
./app/config/application.yml
./backup/config/application.yml
./backup/application.yml.hard
ubuntu@ubuntu:~/05.link$ rm app/config/application.yml 
ubuntu@ubuntu:~/05.link$ cat backup/config/application.yml 
spring:
  datasource:
    url: jdbc:mysql://prod-db.internal:3306/appdb
    username: prod_user
    password: prod_pass!@#
server:
  port: 8080
