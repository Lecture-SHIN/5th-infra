#!/bin/bash
echo "=== 서비스 시작: $(date) ==="
echo "PID: $$"

COUNT=0
while true; do
    COUNT=$((COUNT + 1))
    echo "$(date '+%Y-%m-%d %H:%M:%S') [INFO] 서비스 실행 중 - 요청수: $COUNT"
    sleep 5
done
EOF

