[Unit]
Description=My Practice Application
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/16.systemctl/app
ExecStart=/home/ubuntu/16.systemctl/app/run.sh
Restart=on-failure
RestartSec=5
StandardOutput=append:/home/ubuntu/16.systemctl/app/logs/app.log
StandardError=append:/home/ubuntu/16.systemctl/app/logs/error.log

[Install]
WantedBy=multi-user.target
EOF

